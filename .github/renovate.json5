{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'config:recommended',
    ':semanticCommitsDisabled',
    'customManagers:githubActionsVersions',
    'github>gardener/ci-infra//config/renovate/group-gardener-updates.json5',
    'github>gardener/ci-infra//config/renovate/automerge-with-tide.json5',
  ],
  labels: [
    'kind/enhancement',
  ],
  postUpdateOptions: [
    'gomodTidy',
  ],
  automergeStrategy: 'squash',
  minimumReleaseAge: '3 days',
  customManagers: [
    {
      customType: 'regex',
      managerFilePatterns: [
        '/Makefile$/',
        '/\\.mk$/',
        '/\\.sh$/',
      ],
      matchStrings: [
        '# renovate: datasource=(?<datasource>[a-z-.]+?) depName=(?<depName>[^\\s]+?)(?: (lookupName|packageName)=(?<packageName>[^\\s]+?))?(?: versioning=(?<versioning>[^\\s]+?))?(?: extractVersion=(?<extractVersion>[^\\s]+?))?(?: registryUrl=(?<registryUrl>[^\\s]+?))?\\s.+?_(VERSION|version) *[?:]?= *"?(?<currentValue>.+?)"?\\s',
      ],
    },
  ],
  packageRules: [
    {
      matchDatasources: [
        'go',
      ],
      matchPackageNames: [
        'github.com/gardener/gardener',
        'github.com/gardener/gardener/pkg/apis',
      ],
      automerge: true,
    },
    {
      // Don't bump the go directive in go.mod: gardener depends on TCM, so
      // raising it here would force gardener's toolchain forward on every TCM
      // release. The golang builder image in the Dockerfile is handled by the
      // dockerfile manager and is unaffected.
      matchManagers: [
        'gomod',
      ],
      matchDatasources: [
        'golang-version',
      ],
      enabled: false,
    },
    {
      groupName: 'tools',
      matchFileNames: [
        'hack/tools\\.mk',
      ],
    },
    {
      matchDatasources: [
        'go',
      ],
      enabled: false,
      matchPackageNames: [
        '/k8s\\.io/.+/',
        '/sigs\\.k8s\\.io/controller-runtime/',
      ],
    },
    {
      groupName: 'dependencies',
      matchDatasources: [
        'go',
      ],
      matchPackageNames: [
        'github.com/go-logr/logr',
        'github.com/onsi/ginkgo/v2',
        'github.com/onsi/gomega',
        'golang.org/x/oauth2',
      ],
      separateMajorMinor: true,
      separateMinorPatch: true,
    },
    {
      matchManagers: [
        'gomod',
      ],
      matchUpdateTypes: [
        'patch',
      ],
      enabled: false,
      matchPackageNames: [
        '/go/',
      ],
    },
    {
      groupName: 'github-actions',
      matchManagers: [
        'github-actions',
      ],
    },
    {
      matchFileNames: [
        '.ci/pipeline_definitions',
      ],
      matchPackageNames: [
        'golang',
      ],
      groupName: '[pipeline_definitions] Golang Package Updates',
    },
  ],
}
